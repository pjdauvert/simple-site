    {
      "pageName": "page.getStarted",
      "menuTitle": "Get Started",
      "route": "/get-started",
      "sections": [
        {
          "sectionName": "hero",
          "type": "hero",
          "content": {
            "title": "Up and Running in Minutes",
            "subtitle": "Simple Site is free to host on Netlify and designed for anyone — no technical background required."
          },
          "design": {
            "imageUrl": "/images/backgrounds/get-started.jpg"
          }
        },
        {
          "sectionName": "overview",
          "type": "text",
          "design": {
            "backgroundColor": "#f5f5f5",
            "textColor": "#000000"
          },
          "content": {
            "columns": [
              {
                "title": "How Simple Site Works",
                "paragraph": "Simple Site runs entirely on Netlify — a free, professional hosting platform. Your content lives in Netlify Blob Storage and is served through a fast global CDN. The admin panel lets you manage your site without writing a single line of code. Fork the repository, connect it to Netlify, and you are ready to publish."
              }
            ]
          }
        },
        {
          "sectionName": "steps",
          "type": "text",
          "design": {
            "columnLayout": [1, 1, 1],
            "columnConfig": [
              {
                "textVerticalAlign": "top",
                "textHorizontalAlign": "center",
                "media": {
                  "url": "/images/icons/netlify.svg",
                  "position": "contain",
                  "horizontalAlign": "center",
                  "maxWidth": "120px",
                  "maxHeight": "120px"
                }
              },
              {
                "textVerticalAlign": "top",
                "textHorizontalAlign": "center",
                "media": {
                  "url": "/images/icons/identity.svg",
                  "position": "contain",
                  "horizontalAlign": "center",
                  "maxWidth": "120px",
                  "maxHeight": "120px"
                }
              },
              {
                "textVerticalAlign": "top",
                "textHorizontalAlign": "center",
                "media": {
                  "url": "/images/icons/github.svg",
                  "position": "contain",
                  "horizontalAlign": "center",
                  "maxWidth": "120px",
                  "maxHeight": "120px"
                }
              }
            ]
          },
          "content": {
            "columns": [
              {
                "title": "1. Create a Netlify Account",
                "paragraph": "Sign up at netlify.com for free. Netlify handles hosting, serverless functions and secure content storage — all in one platform with a generous free tier."
              },
              {
                "title": "2. Enable Netlify Identity",
                "paragraph": "Activate Netlify Identity in your project settings to secure the admin panel. Invite yourself as the first admin user — no extra configuration required."
              },
              {
                "title": "3. Fork on GitHub",
                "paragraph": "Fork the Simple Site repository to your GitHub account, then connect it to Netlify with one click. Every push to your main branch deploys automatically to production."
              }
            ]
          }
        }
      ]
    }
