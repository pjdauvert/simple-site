# Copy this file to .env and fill in the values.
# .env is gitignored — never commit secrets.

# ── Netlify Functions ────────────────────────────────────────────────────────
# Blob store name prefix used by ConfigModule and TranslationsModule.
# In local dev this creates a directory-based blob store under .netlify/blobs/.
APP_NAME=simple-site-dev

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# Set to "true" to bypass Netlify Identity and use a local mock auth session.
# Required for local dev because @netlify/identity needs a live Netlify site URL.
VITE_AUTH_BYPASS=true
