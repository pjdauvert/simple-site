{
  "name": "interfaces",
  "projectType": "library",
  "sourceRoot": "libs/interfaces/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/interfaces"],
      "inputs": ["{projectRoot}/src/**/*.ts", "{projectRoot}/tsconfig.lib.json"],
      "options": {
        "commands": [
          "rm -f node_modules/.tmp/tsconfig.interfaces.tsbuildinfo",
          "tsc -p libs/interfaces/tsconfig.lib.json"
        ],
        "parallel": false
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint libs/interfaces/src"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p libs/interfaces/tsconfig.lib.json --noEmit"
      }
    }
  },
  "tags": []
}
